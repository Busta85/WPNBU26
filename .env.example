# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TWILIO_ACCOUNT_SID: Twilio Account SID for sending SMS
TWILIO_ACCOUNT_SID=

# TWILIO_AUTH_TOKEN: Twilio Auth Token for sending SMS
TWILIO_AUTH_TOKEN=

# TWILIO_PHONE_NUMBER: Twilio Sender Phone Number (e.g., +1234567890)
TWILIO_PHONE_NUMBER=

# SMTP_HOST: The hostname of your SMTP server (e.g., smtp.gmail.com). Defaults to smtp.gmail.com.
SMTP_HOST=

# SMTP_PORT: The port to connect to. Defaults to 587.
SMTP_PORT=

# SMTP_USER: Your SMTP email address or username.
SMTP_USER=

# SMTP_PASSWORD: The application-specific password or password for the SMTP user.
SMTP_PASSWORD=
